# lock files are generally recommended to be committed
#
Pipfile.lock 
poetry.lock
uv.lock

# Test and coverage
.coverage
.pytest_cache/
nosetests.xml
coverage.xml

# Runtime files
*.sqlite3
*.db
.env # Recommended for sensitive information like API keys
.flaskenv

# OS-generated files
.DS_Store # macOS
Thumbs.db # Windows

.history